{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noUnusedLocals": false,
    "paths": {
      "@cartfolio/shared": ["../shared/types/index.ts"],
      "@cartfolio/shared/*": ["../shared/*"]
    }
  },
  "include": ["src"]
}
